{
    "name": "rollpix/module-image-flip-hover",
    "description": "Magento 2 module for product image hover effects on PLP. Supports image flip (single alternate image) and gallery slider (navigate all images with arrows, mouse tracking, swipe). Compatible with Luma and Hyvä themes.",
    "type": "magento2-module",
    "version": "2.0.3",
    "license": "MIT",
    "keywords": [
        "magento2",
        "magento 2",
        "module",
        "image",
        "hover",
        "flip",
        "product",
        "gallery",
        "animation",
        "page builder",
        "widget"
    ],
    "homepage": "https://github.com/ROLLPIX/M2-ImageFlipHover",
    "authors": [
        {
            "name": "Rollpix",
            "email": "support@rollpix.com",
            "homepage": "https://rollpix.com"
        }
    ],
    "support": {
        "issues": "https://github.com/ROLLPIX/M2-ImageFlipHover/issues",
        "source": "https://github.com/ROLLPIX/M2-ImageFlipHover"
    },
    "require": {
        "php": "^7.4||^8.0||^8.1||^8.2||^8.3",
        "magento/framework": "^103.0",
        "magento/module-catalog": "^104.0",
        "magento/module-catalog-widget": "^100.4",
        "magento/module-store": "^101.1",
        "magento/module-eav": "^102.1"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Rollpix\\ImageFlipHover\\": ""
        }
    }
}
