<?xml version="1.0"?>
<!--
/**
 * @author Rollpix
 * @package Rollpix_ImageFlipHover
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="rollpix" translate="label" sortOrder="999">
            <label>ROLLPIX</label>
        </tab>
        <section id="rollpix_imageflip" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>Image Flip Hover</label>
            <tab>rollpix</tab>
            <resource>Rollpix_ImageFlipHover::config</resource>

            <!-- ==================== GENERAL ==================== -->
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Configuración General</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Habilitar o deshabilitar el módulo.</comment>
                </field>
                <field id="mode" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Modo</label>
                    <source_model>Rollpix\ImageFlipHover\Model\Config\Source\HoverMode</source_model>
                    <comment><![CDATA[<strong>Flip:</strong> Muestra una imagen alternativa al pasar el mouse. <strong>Slider:</strong> Permite navegar todas las imágenes de la galería del producto.]]></comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- ==================== FLIP MODE ==================== -->
            <group id="flip" translate="label comment" type="text" sortOrder="12" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Modo Flip</label>
                <comment>Configuración del efecto de cambio de imagen (solo aplica en modo Flip).</comment>
                <field id="primary_role" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Rol de Imagen Principal</label>
                    <source_model>Rollpix\ImageFlipHover\Model\Config\Source\ImageRoles</source_model>
                    <comment><![CDATA[Rol de imagen a mostrar en hover. "Segunda Imagen de Galería" usa la segunda imagen por posición.]]></comment>
                    <depends><field id="rollpix_imageflip/general/mode">flip</field></depends>
                </field>
                <field id="fallback_role" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Rol de Imagen de Respaldo</label>
                    <source_model>Rollpix\ImageFlipHover\Model\Config\Source\ImageRoles</source_model>
                    <comment>Se usa si el producto no tiene imagen con el rol principal.</comment>
                    <depends><field id="rollpix_imageflip/general/mode">flip</field></depends>
                </field>
                <field id="animation_type" translate="label comment" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Tipo de Animación</label>
                    <source_model>Rollpix\ImageFlipHover\Model\Config\Source\AnimationType</source_model>
                    <comment>Efecto de transición visual al hacer hover.</comment>
                    <depends><field id="rollpix_imageflip/general/mode">flip</field></depends>
                </field>
                <field id="animation_speed" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Velocidad de Animación (ms)</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <comment>Duración de la animación en milisegundos. Por defecto: 300</comment>
                    <depends><field id="rollpix_imageflip/general/mode">flip</field></depends>
                </field>
            </group>

            <!-- ==================== SLIDER MODE ==================== -->
            <group id="hover_slider" translate="label comment" type="text" sortOrder="13" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Modo Slider</label>
                <comment>Configuración de la navegación de galería (solo aplica en modo Slider).</comment>
                <field id="enable_hover_flip" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Hover Flip</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Al hacer hover, avanza automáticamente a la segunda imagen.</comment>
                    <depends><field id="rollpix_imageflip/general/mode">slider</field></depends>
                </field>
                <field id="transition_type" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Tipo de Transición</label>
                    <source_model>Rollpix\ImageFlipHover\Model\Config\Source\TransitionType</source_model>
                    <depends><field id="rollpix_imageflip/general/mode">slider</field></depends>
                </field>
                <field id="transition_speed" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Velocidad de Transición (ms)</label>
                    <validate>validate-number validate-greater-than-zero</validate>
                    <comment>Por defecto: 250</comment>
                    <depends><field id="rollpix_imageflip/general/mode">slider</field></depends>
                </field>
                <field id="max_images" translate="label comment" type="text" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Máximo de Imágenes</label>
                    <validate>validate-number</validate>
                    <comment>Cantidad máxima de imágenes por producto (2-20). Por defecto: 8</comment>
                    <depends><field id="rollpix_imageflip/general/mode">slider</field></depends>
                </field>
                <field id="configurable_images_per_child" translate="label comment" type="text" sortOrder="45" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Imágenes por Variante</label>
                    <validate>validate-number</validate>
                    <comment><![CDATA[Para configurables: máximo de imágenes de cada hijo/variante. 1 = solo la primera foto de cada color. 0 = todas. Por defecto: 0.]]></comment>
                    <depends><field id="rollpix_imageflip/general/mode">slider</field></depends>
                </field>
                <field id="variant_selector_attributes" translate="label comment" type="multiselect" sortOrder="47" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Atributos que Diferencian Imágenes</label>
                    <source_model>Rollpix\ImageFlipHover\Model\Config\Source\ConfigurableAttributes</source_model>
                    <comment><![CDATA[Para configurables: atributos (ej: <strong>Color</strong>) cuyas variantes deben mostrar imágenes diferentes. El módulo usa el primer atributo de la lista que sea eje de variación del producto y muestra una sola variante por cada valor distinto (ej: una foto por color, sin repetir por talle). <strong>Vacío = usa las imágenes de todas las variantes</strong> (comportamiento clásico).]]></comment>
                    <depends><field id="rollpix_imageflip/general/mode">slider</field></depends>
                </field>
                <field id="loop" translate="label comment" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Navegación Circular</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Navegar de la última imagen a la primera y viceversa.</comment>
                    <depends><field id="rollpix_imageflip/general/mode">slider</field></depends>
                </field>
            </group>

            <!-- ==================== DESKTOP ==================== -->
            <group id="desktop" translate="label" type="text" sortOrder="14" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Desktop</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar en Desktop</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Activar el módulo en dispositivos de escritorio (pantallas mayores a 768px).</comment>
                </field>
                <field id="navigation" translate="label comment" type="multiselect" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Navegación</label>
                    <source_model>Rollpix\ImageFlipHover\Model\Config\Source\DesktopNavigationType</source_model>
                    <comment>Métodos de navegación. Se pueden activar varios simultáneamente.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="indicator" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Indicador de Posición</label>
                    <source_model>Rollpix\ImageFlipHover\Model\Config\Source\IndicatorType</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="indicator_position" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Posición del Indicador</label>
                    <source_model>Rollpix\ImageFlipHover\Model\Config\Source\IndicatorPosition</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- ==================== MOBILE ==================== -->
            <group id="mobile" translate="label" type="text" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Mobile</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Habilitar en Mobile</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Activar el módulo en dispositivos móviles (pantallas menores a 768px).</comment>
                </field>
                <field id="navigation" translate="label comment" type="multiselect" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Navegación</label>
                    <source_model>Rollpix\ImageFlipHover\Model\Config\Source\MobileNavigationType</source_model>
                    <comment>Métodos de navegación en dispositivos móviles.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="indicator" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Indicador de Posición</label>
                    <source_model>Rollpix\ImageFlipHover\Model\Config\Source\IndicatorType</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="indicator_position" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Posición del Indicador</label>
                    <source_model>Rollpix\ImageFlipHover\Model\Config\Source\IndicatorPosition</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>

            <!-- ==================== LOCATIONS ==================== -->
            <group id="locations" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Ubicaciones Habilitadas</label>
                <field id="category_page" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Páginas de Categoría</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="widget_products" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Widgets de Productos (Sliders/Grids)</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="search_results" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Resultados de Búsqueda</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="related_products" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Productos Relacionados/Upsell/Cross-sell</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="cms_blocks" translate="label comment" type="select" sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Bloques CMS</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Widgets de productos insertados en bloques y páginas CMS.</comment>
                </field>
                <field id="page_builder" translate="label comment" type="select" sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Page Builder</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Widget de Productos de Page Builder.</comment>
                </field>
            </group>

            <!-- ==================== INFO ==================== -->
            <group id="info" translate="label" sortOrder="999" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Información del Módulo</label>
                <field id="module_name" translate="label" type="label" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Módulo</label>
                    <comment>Rollpix_ImageFlipHover</comment>
                </field>
                <field id="module_version" translate="label" type="label" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Versión</label>
                    <frontend_model>Rollpix\ImageFlipHover\Block\Adminhtml\System\Config\ModuleVersion</frontend_model>
                </field>
                <field id="module_repo" translate="label" type="label" sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Repositorio</label>
                    <comment><![CDATA[<a href="https://github.com/ROLLPIX/M2-ImageFlipHover" target="_blank">GitHub</a>]]></comment>
                </field>
                <field id="module_manual" translate="label" type="label" sortOrder="40" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Manual de usuario</label>
                    <comment><![CDATA[<a href="https://github.com/ROLLPIX/M2-ImageFlipHover/blob/master/manual.md" target="_blank">Ver manual</a>]]></comment>
                </field>
            </group>
        </section>
    </system>
</config>
